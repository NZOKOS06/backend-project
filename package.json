{
  "name": "pharma-stock-backend",
  "version": "1.0.0",
  "description": "Backend API for pharmacy stock management",
  "main": "server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "node scripts/init-db.js",
    "migrate": "node scripts/migrate-add-open-available.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:security": "node test-security.js",
    "security:check": "node scripts/security-check.js",
    "check:secrets": "node scripts/check-secrets.js",
    "lint": "eslint .",
    "prebuild": "npm run security:check && npm run check:secrets"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "redis": "^5.10.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}
