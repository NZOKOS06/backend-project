# Server
PORT=5000
HOST=0.0.0.0

# Database — option A: local (DB_*)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pharmastock
DB_USER=postgres
DB_PASSWORD=your_password

# Database — option B: Railway / external (DATABASE_URL)
# DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Auth (obligatoire en prod)
JWT_SECRET=your_secret_key_here

# CORS (optionnel) — URLs du frontend séparées par des virgules
# CORS_ORIGIN=https://mon-front.vercel.app,https://mon-front.pages.dev
# FRONTEND_URL=https://mon-front.vercel.app
